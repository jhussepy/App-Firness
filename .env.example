# Copy to .env.local for local development. In Vercel (production web build),
# set these as Environment Variables instead — see Settings > Environment Variables.
# Both values come from your Supabase project: Settings > API.
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
